{
  "manifest_version": 3,
  "name": "Overleaf AI Assistant",
  "version": "0.1",
  "description": "Multi-provider AI proofreading and style assistant for the Overleaf LaTeX editor. Supports Anthropic Claude, Google Gemini, and OpenRouter.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.overleaf.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://www.overleaf.com/project/*"],
      "js": [
        "content/content.js",
        "content/sidebar.js",
        "content/highlights.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    },
    "default_title": "Overleaf AI Assistant"
  },
  "icons": {
    "48": "icons/icon48.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "overleaf-ai-assistant@extension",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": ["none"]
      }
    }
  }
}
